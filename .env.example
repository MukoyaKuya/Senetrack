# Copy to .env and fill in. Do not commit .env (it is gitignored).

# Neon Postgres (from Neon dashboard → Connection string)
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Optional
# REDIS_URL=redis://...
# DJANGO_SECRET_KEY=your-secret-key
# # Security & Debugging
DJANGO_DEBUG=false
DJANGO_ADMIN_PATH=manage-senetrack
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SECRET_KEY=yoursecretkeyhere
